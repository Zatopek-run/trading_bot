# Binance API (da https://www.binance.com/it/my/settings/api-management)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Telegram (da @BotFather su Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Impostazioni trading
TRADE_SYMBOL=BTCUSDT
TRADE_QUANTITY=0.001          # Quantità base per ordine
MAX_OPEN_TRADES=3             # Massimo trade aperti contemporaneamente
USE_TESTNET=true              # true = testnet Binance, false = produzione reale

# Stop-loss / Take-profit automatici
ENABLE_SL_TP=true
STOP_LOSS_PCT=2.0             # Chiude in perdita a -2% dall'entry
TAKE_PROFIT_PCT=4.0          # Chiude in profitto a +4% dall'entry

# Parametri strategia
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
VOLUME_MA_PERIOD=20
VOLUME_THRESHOLD=1.5          # Volume deve essere X volte la media

# Esperimento / Dashboard
INITIAL_CAPITAL=100           # Capitale iniziale (mostrato in dashboard)
GOAL_CAPITAL=1000             # Obiettivo
EXPERIMENT_DAYS=7             # Durata esperimento in giorni
BENCHMARK_SYMBOL=BTCUSDT      # Simbolo per il confronto Buy & Hold
DB_PATH=data/trading.db

# Dashboard web (login + HTTPS via Caddy)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=cambia_questa_password
DASHBOARD_SECRET=genera-una-stringa-random-lunga
DASHBOARD_PORT=8000
DASHBOARD_DOMAIN=trading.tuodominio.com   # dominio per HTTPS automatico (Caddy)
