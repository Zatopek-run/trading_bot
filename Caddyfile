# Automatic HTTPS via Let's Encrypt. Caddy obtains + renews the certificate
# for {$DASHBOARD_DOMAIN} as long as the domain's A record points to this VPS.

{$DASHBOARD_DOMAIN} {
    reverse_proxy dashboard:8000

    encode gzip

    # Basic hardening headers.
    header {
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
    }

    log {
        output stdout
    }
}
